// Zed editor settings
{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "cli_default_open_behavior": "new_window",
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": null,
  },
  "git_panel": {
    "dock": "left",
  },
  "language_models": {
    "ollama": {
      "api_url": "http://localhost:11434",
    },
  },
  "edit_predictions": {
    "provider": "none",
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "Nordic Syntax",
  },
  "vim_mode": true,
  "agent": {
    "enabled": false,
    "dock": "right",
    "default_profile": "write",
    "default_model": {
      "effort": "high",
      "provider": "deepseek",
      "model": "deepseek-v4-flash",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "buffer_font_family": "FiraCode Nerd Font",
  "buffer_font_size": 16,
  "terminal": {
    "font_family": "FiraCode Nerd Font",
    "font_size": 16,
  },
  "tab_bar": { "show": false },
  "file_scan_exclusions": ["ai/responses/**/*.md"],
  "tab_size": 2,
  "languages": {
    "Python": {
      "tab_size": 4,
      "hard_tabs": false,
    },
  },
}
