#!/usr/bin/env bash
#  _____  ___
# /__   \/ __\  Tangerine Cat, kaineer@gmail.com
#   / /\/ /
#  / / / /___   github: https://github.com/kaineer
#  \/  \____/   twitter: https://twitter.com/kaineer
#
# What: Run some commands by domain name
#

_usage() {
  echo "## THE WHAT"
  echo "\`\`\`sh"
  echo " $ the path      # all parts of current executables path"
  echo " $ the net       # address of current available network"
  echo " $ the net restart"
  echo "                 # restart network services"
  echo " $ the ssh       # list all ssh hosts, check availability"
  echo " $ the uname     # uname active parts"
  echo " $ the arch      # architecture for binaries"
  echo " $ the kill      # kill selected process"
  echo "\`\`\`"
}

echo_usage() {
  if [[ "$(which bat)" == "" ]]; then
    _usage
  else
    _usage | bat -lmd -p
  fi
}

echo_path() {
  echo "$PATH" | sed "s/:/\\n/g" | grep -v "^$"
}

net_functions() {
  case "$1" in
  "restart") sudo systemctl restart NetworkManager ;;
  *) echo_net ;;
  esac
}

echo_net() {
  ip -j a | jq -r '.[] | select(.addr_info[]?.family == "inet") | [.ifname, (.addr_info[] | select(.family=="inet") | .local)] | @tsv'
}

echo_uname() {
  echo "nodename: $(uname -n)"
  echo "machine: $(uname -m)"
  echo "operating_system: $(uname -s | tr '[A-Z]' '[a-z]')"
}

echo_architecture() {
  OS="$(uname -s | tr '[A-Z]' '[a-z]')"
  MACHINE="$(uname -m)"
  echo "${OS}-${MACHINE}"
}

kill_selected() {
  PID=$(ps ux | fzf | sed "s/ \+/ /g" | cut -f2 -d" ")
  [[ "$PID" != "" ]] && kill -9 $PID
}

list_available_hosts() {
  grep -h "^Host " ~/.ssh/config ~/.ssh/hosts/* 2>/dev/null | awk '{for(i=2;i<=NF;i++) if($i!="*") print $i}' | sort -u
}

__check_ssh() {
  local host=$1
  local timeout=5

  # Попытка SSH-подключения с таймаутом (без реальной авторизации)
  ssh -o ConnectTimeout=$timeout \
    -o BatchMode=yes \
    -o StrictHostKeyChecking=no \
    -o NumberOfPasswordPrompts=0 \
    "$host" "exit" 2>/dev/null </dev/null

  return $?
}

list_ssh_hosts() {
  while IFS= read -r host; do
    # Пропускаем пустые строки и комментарии
    [[ -z "$host" || "$host" =~ ^[[:space:]]*# ]] && continue

    printf " * %-10s " "$host:"

    if __check_ssh "$host"; then
      echo "✅ online"
    else
      echo "❌ offline"
    fi
  done < <(list_available_hosts)
}

case "$1" in
"path") echo_path ;;
"net") shift && net_functions $@ ;;
"uname") echo_uname ;;
"arch") echo_architecture ;;
"kill") kill_selected ;;
"ssh") list_ssh_hosts ;;
"h" | "") echo_usage ;;
esac
