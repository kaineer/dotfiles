#!/usr/bin/env bash

#  _____  ___
# /__   \/ __\  Tangerine Cat, kaineer@gmail.com
#   / /\/ /
#  / / / /___   github: https://github.com/kaineer
#  \/  \____/   twitter: https://twitter.com/kaineer
#
# What: variables to use in another scripts
#

SDIR="$HOME/var/vars"

ensure_storage() {
  [ ! -d $SDIR ] && mkdir -p $SDIR
}

get_var() {
  NAME=$1
  FNAME="$SDIR/$NAME"
  if [ -f "$FNAME" ]; then
    cat "$FNAME"
  fi
}

set_var() {
  NAME=$1
  VALUE=$2
  FNAME="$SDIR/$NAME"

  if [[ "$VALUE" == "" ]]; then
    [ -f "$FNAME" ] && rm $FNAME
  else
    ensure_storage
    echo "$VALUE" >$FNAME
  fi
}

list_vars() {
  [ ! -d $SDIR ] && return

  cd $SDIR
  for file in $(ls -1); do
    local value=$(cat $file)
    local lines=$(echo -e "$value" | wc -l)
    if [[ "$lines" == "0" ]]; then
      echo -ne ""
    elif [[ "$lines" == "1" ]]; then
      echo "$file: $value"
    else
      echo "$file: |"
      echo "$value" | sed "s/^/  /"
    fi
  done
  cd - >/dev/null 2>&1
}

rm_var() {
  NAME="$1"
  FNAME="$SDIR/$NAME"
  [ -f "$FNAME" ] && rm "$FNAME"
}

store_clip() {
  NAME="$1"
  CLIPBOARD="$(xsel -ob)"
  set_var "$NAME" "$CLIPBOARD"
}

usage() {
  echo "Usage:"
  echo " $ var name        # Variable value to stdout"
  echo " $ var name value  # Store value for variable"
  echo " $ var --delete|rm # Remove value for variable"
  echo " $ var -i name     # Store clipboard to variable"
  echo " $ var -l | ls     # List variables with values"
}

case "$1" in
"-l" | "--list" | "ls" | "list")
  list_vars
  ;;
"-d" | "--delete" | "rm")
  shift
  rm_var $@
  ;;
"--help" | "h" | "help") usage ;;
"-i" | "clip")
  shift
  store_clip $@
  ;;
*)
  if [[ "${#@}" == "1" ]]; then
    get_var "$1"
  elif [[ "${#@}" == "2" ]]; then
    set_var "$1" "$2"
  fi
  ;;
esac
