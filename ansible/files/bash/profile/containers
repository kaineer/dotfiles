[[ "$1" != "-i" ]] && return

DOCKER_BIN=""

if [[ "$(which podman)" != "" ]]; then
  DOCKER_BIN="podman"
  # alias dc=podman-compose
  alias dc="~/.podman-compose-venv/bin/podman-compose"
  alias d=podman
  alias dps="podman ps"
  alias dpsf='podman ps --format "{{.ID}}|{{.Names}}|{{.Status}}" | awk -F"|" '\''{printf "%-15s | %-25s | %s\n", $1, $2, $3}'\'
  alias dpsi="podman ps --format \"{{.ID}}\""

  dk() {
    LINE=$(podman ps --format "{{.ID}} | {{.Names}}" | fzf -0)
    if [[ "$LINE" != "" ]]; then
      ID=$(echo $LINE | awk '{ print $1 }')
      $DOCKER_BIN kill $ID
      $DOCKER_BIN rm $ID
    fi
  }

elif [[ "$(which docker)" == "" ]]; then
  DOCKER_BIN="docker"
  alias dc=docker-compose
  alias d=docker
  alias drm="docker rm"
  alias dk="docker kill"
  alias dps="docker ps"

  drk() {
    docker kill $@
    docker rm $@
  }
fi
