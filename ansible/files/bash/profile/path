### NOTE: this line means we should fix path
###   for non-interactive shell
if [[ "$1" == "-i" ]]; then
  
  # Fix ollama path
  [ -d "$HOME/ollama/bin" ] && export PATH="$HOME/ollama/bin:$PATH"

  # FIx llama path
  if [ -d "$HOME/llama/bin" ]; then
    export PATH="$HOME/llama/bin:$PATH"
    eval "$(llama-cli --completion-bash)"
  fi
else
  # 1. remove duplicates, remove $HOME/bin
  # 2. prepend with $HOME/bin
  
  FIXED_PATH=$(echo $PATH | tr ':' '\n' | grep -v "^$" | grep -v "$HOME/bin" | sort | uniq | tr '\n' ':')
  
  [ -d "$HOME/bin" ] && export PATH="$HOME/bin:$PATH"
  [ -d "$HOME/.config/emacs/bin" ] && export PATH="$HOME/.config/emacs/bin:$PATH"
fi
